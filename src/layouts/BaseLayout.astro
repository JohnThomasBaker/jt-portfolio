---
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";
const { title = "JT", description = "Portfolio", mainClass = "page-default" } = Astro.props;

const STORE_URL = "https://jtsounds.com";

const nav = [
  { href: "/", label: "Home" },
  { href: "/music", label: "Music" },
  { href: "/lessons", label: "Lessons" },
  { href: "/me", label: "Me" },
  { href: STORE_URL, label: "Store", external: true },
];
---
<!doctype html>
<html lang="en" class="js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ViewTransitions />

    <style is:global>
      :root { color-scheme: dark; }
      body {
        margin: 0;
        background: transparent;
        color: var(--text);
        font-family: "Times New Roman", Times, serif;
        font-size: clamp(1.08rem, 0.35vw + 1rem, 1.2rem);
        line-height: 1.72;
        font-weight: 540;
        letter-spacing: 0.01em;
      }
      a { color: inherit; text-decoration: none; }
      a:hover { text-decoration: underline; }

      .wrap { max-width: 980px; /* left-align instead of center */ margin: 0 0 0 24px; padding: 24px; }
      main.wrap { padding-top: 0; }
main.wrap > :first-child { margin-top: 0 !important; }

    
      .brand { font-weight: 700; letter-spacing: 0.2px; }
      .links { display:flex; gap: 14px; flex-wrap: wrap; font-size: 1rem; color: rgba(255,255,255,0.85); }
      .links a { padding: 6px 8px; border-radius: 0; }
      .links a:hover { background: rgba(255,255,255,0.08); text-decoration: none; }

    
      h1 { margin: 0 0 10px; font-size: 34px; color: var(--tone-jacquard); }
      h2 { color: var(--tone-heading); }
      h3, .section-title { color: var(--tone-heading); }
      p, .muted, body *:not(h1):not(h2):not(h3):not(.section-title) {
        color: var(--text-muted) !important;
      }
      .section-title { color: var(--tone-moss) !important; } /* fallback */
      .st-green { color: var(--tone-moss) !important; }
      .st-red { color: var(--tone-clay) !important; }
      .st-navy { color: var(--tone-slate) !important; }
      .st-bronze { color: var(--tone-bronze) !important; }
      .st-plum { color: var(--tone-plum) !important; }
      .st-teal { color: var(--tone-teal) !important; }
      .card {
       padding: 0;
       border: none;
      background: none;
     }

      
      .muted { color: var(--text-muted); }

      .fadein {
        /* start opacity can be overridden; defaults to 0 unless a bg is set */
        opacity: var(--fade-start-opacity, 0);
        transform: translate3d(0, var(--fade-y, 12px), 0);
        filter: blur(var(--fade-blur, 0px));
        background-color: var(--fade-bg, var(--page-bg, transparent));
        transition:
          opacity var(--fade-dur, 2400ms) cubic-bezier(.2,.8,.2,1),
          transform var(--fade-dur, 2400ms) cubic-bezier(.2,.8,.2,1),
          filter var(--fade-blur-dur, var(--fade-dur, 2400ms)) ease,
          background-color var(--fade-dur, 2400ms) ease;
        will-change: opacity, transform, filter, background-color;
      }
      .fadein.is-in {
        opacity: 1;
        transform: translate3d(0, 0, 0);
        filter: blur(0);
        background-color: transparent;
      }
      @media (prefers-reduced-motion: reduce) {
        .fadein { opacity: 1; transform: none; transition: none; filter: none; background-color: none; }
      }

      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation-duration: 340ms;
        animation-timing-function: cubic-bezier(.22, .8, .2, 1);
      }

      ::view-transition-old(root) {
        animation-name: jt-page-fade-out;
      }

      ::view-transition-new(root) {
        animation-name: jt-page-fade-in;
      }

      @keyframes jt-page-fade-out {
        from { opacity: 1; filter: blur(0); }
        to { opacity: 0; filter: blur(2px); }
      }

      @keyframes jt-page-fade-in {
        from { opacity: 0; filter: blur(2px); }
        to { opacity: 1; filter: blur(0); }
      }

      .page-shell {
        opacity: 0;
        animation: jt-initial-load-fade 420ms ease forwards;
      }

      @keyframes jt-initial-load-fade {
        from { opacity: 0; }
        to { opacity: 1; }
      }

      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(root),
        ::view-transition-new(root) {
          animation-duration: 1ms;
        }

        .page-shell {
          animation: none;
          opacity: 1;
        }
      }
    </style>

    <noscript>
      <style>
        .fadein { opacity: 1 !important; transform: none !important; }
      </style>
    </noscript>

    
  </head>
<script is:inline>
  const initFade = () => {
    const els = document.querySelectorAll(".fadein");
    if (!els.length) return;

    els.forEach((el) => {
      if (el.dataset.fadeInit === "1") return; // prevent double-init
      el.dataset.fadeInit = "1";

      const y = el.dataset.y || 0;
      const blur = el.dataset.blur || 0;
      const dur = el.dataset.dur || 2400;
      const bg = el.dataset.bg || "";
      el.style.setProperty("--fade-y", y + "px");
      el.style.setProperty("--fade-blur", blur + "px");
      el.style.setProperty("--fade-dur", dur + "ms");
      // make blur finish a bit sooner than the rest
      el.style.setProperty("--fade-blur-dur", Math.max(dur * 0.8, 0) + "ms");
      if (bg) {
        el.style.setProperty("--fade-bg", bg);
        el.style.setProperty("--fade-start-opacity", 1);
      } else {
        el.style.setProperty("--fade-start-opacity", 0);
      }
    });

    const reveal = (el) => {
      const delay = parseInt(el.dataset.delay || 0, 10);
      setTimeout(() => el.classList.add("is-in"), delay);
    };

    if (!("IntersectionObserver" in window)) {
      els.forEach(reveal);
      return;
    }

    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        reveal(e.target);
        if (e.target.dataset.once === "1") io.unobserve(e.target);
      }
    }, { threshold: 0.12 });

    els.forEach((el) => io.observe(el));
    els.forEach((el) => {
      if (el.getBoundingClientRect().top < window.innerHeight) {
        reveal(el);
      }
    });
  };

  const initHeroScrollFade = () => {
    if (window.__heroScrollCleanup) window.__heroScrollCleanup();

    const hero = document.querySelector(".hero");
    if (!hero) {
      window.__heroScrollCleanup = null;
      return;
    }

    const FAST_FADE_MULTIPLIER = 0.16;
    const NORMAL_FADE_MULTIPLIER = 0.26;
    const FAST_UP_VELOCITY_THRESHOLD = -1.2; // px/ms

    let lastScrolled = 0;
    let lastTime = performance.now();

    const update = () => {
      const rect = hero.getBoundingClientRect();
      const scrolled = Math.max(0, -rect.top);
      const now = performance.now();
      const dt = Math.max(now - lastTime, 1);
      const velocity = (scrolled - lastScrolled) / dt;
      const isFastUpScroll = velocity < FAST_UP_VELOCITY_THRESHOLD;
      const fadeMultiplier = isFastUpScroll ? NORMAL_FADE_MULTIPLIER : FAST_FADE_MULTIPLIER;
      const fadeDistance = Math.max(hero.offsetHeight * fadeMultiplier, 1);
      const progress = Math.min(scrolled / fadeDistance, 1);
      const stepped = Math.round(progress * 22) / 22;
      hero.style.setProperty("--hero-progress", stepped.toFixed(4));
      lastScrolled = scrolled;
      lastTime = now;
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        ticking = false;
        update();
      });
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
    update();

    window.__heroScrollCleanup = () => {
      window.removeEventListener("scroll", onScroll);
      window.removeEventListener("resize", onScroll);
    };
  };

  const initSectionTitlePalette = () => {
    const targets = Array.from(document.querySelectorAll(".section-title, main.page-home h1:not(.hero-subtitle)"));
    if (!targets.length) return;

    const classes = ["st-green", "st-red", "st-navy", "st-bronze", "st-plum", "st-teal"];
    // Start offset changes each load, then cycle so adjacent titles are always different.
    const start = Math.floor(Math.random() * classes.length);

    let idx = 0;
    targets.forEach((el) => {
      if (classes.some((className) => el.classList.contains(className))) return;
      el.classList.remove(...classes);
      el.classList.add(classes[(start + idx) % classes.length]);
      idx += 1;
    });
  };

  const initNavShift = () => {
    if (window.__navShiftCleanup) window.__navShiftCleanup();

    const trigger = document.querySelector(".logo-sidebar");
    if (!trigger) {
      window.__navShiftCleanup = null;
      return;
    }

    const openNav = () => document.body.classList.add("nav-open");
    const closeNav = () => document.body.classList.remove("nav-open");
    const onFocusOut = (e) => {
      if (trigger.contains(e.relatedTarget)) return;
      closeNav();
    };

    trigger.addEventListener("mouseenter", openNav);
    trigger.addEventListener("mouseleave", closeNav);
    trigger.addEventListener("focusin", openNav);
    trigger.addEventListener("focusout", onFocusOut);

    window.__navShiftCleanup = () => {
      closeNav();
      trigger.removeEventListener("mouseenter", openNav);
      trigger.removeEventListener("mouseleave", closeNav);
      trigger.removeEventListener("focusin", openNav);
      trigger.removeEventListener("focusout", onFocusOut);
    };
  };

  // First load
  document.addEventListener("DOMContentLoaded", () => {
    initFade();
    initHeroScrollFade();
    initSectionTitlePalette();
    initNavShift();
  });
  // Astro client-side navigations / view transitions
  document.addEventListener("astro:page-load", () => {
    initFade();
    initHeroScrollFade();
    initSectionTitlePalette();
    initNavShift();
  });
</script>
  <body>
    <header class="nav">
      <div class="nav-inner">
        <div class="logo-sidebar">
          <img src="/images/logo.png" alt="JT Logo" class="logo" />

          <div class="sidebar" aria-label="Site navigation">
            <a href="/">Home</a>
            <a href="/music">Music</a>
            <a href="/lessons">Lessons</a>
            <a href="/me">Me</a>
          </div>
        </div>
      </div>
    </header>

    <div class="page-shell">
      <main class={mainClass}>
        <slot />
      </main>

      <footer class="wrap muted" style="padding-top:0; padding-bottom:28px;">
        <small>© {new Date().getFullYear()} JT</small>
      </footer>
    </div>
  </body>
</html>
