---
import "../styles/global.css";
const { title = "JT", description = "Portfolio" } = Astro.props;

const STORE_URL = "https://jtsounds.com";

const nav = [
  { href: "/", label: "Home" },
  { href: "/music", label: "Music" },
  { href: "/lessons", label: "Lessons" },
  { href: "/me", label: "Me" },
  { href: STORE_URL, label: "Store", external: true },
];
---
<!doctype html>
<html lang="en" class="js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <style is:global>
      :root { color-scheme: dark; }
      body {
        margin: 0;
        background: #0a0a0a;
        color: #f3f3f3;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
      }
      a { color: inherit; text-decoration: none; }
      a:hover { text-decoration: underline; }

      .wrap { max-width: 980px; margin: 0 auto; padding: 24px; }
      main.wrap { padding-top: 0; }
main.wrap > :first-child { margin-top: 0 !important; }

    
      .brand { font-weight: 700; letter-spacing: 0.2px; }
      .links { display:flex; gap: 14px; flex-wrap: wrap; font-size: 14px; color: rgba(255,255,255,0.85); }
      .links a { padding: 6px 8px; border-radius: 10px; }
      .links a:hover { background: rgba(255,255,255,0.08); text-decoration: none; }

    
      h1 { margin: 0 0 10px; font-size: 34px; }
      p { line-height: 1.6; color: rgba(255,255,255,0.82); }
      .card {
       padding: 0;
       border: none;
      background: none;
     }

      
      .muted { color: rgba(255,255,255,0.65); }

      .fadein {
        opacity: 0;
        transform: translate3d(0, var(--fade-y, 12px), 0);
        transition:
          opacity 650ms cubic-bezier(.2,.8,.2,1),
          transform 650ms cubic-bezier(.2,.8,.2,1);
        will-change: opacity, transform;
      }
      .fadein.is-in {
        opacity: 1;
        transform: translate3d(0, 0, 0);
      }
      @media (prefers-reduced-motion: reduce) {
        .fadein { opacity: 1; transform: none; transition: none; }
      }
    </style>

    <noscript>
      <style>
        .fadein { opacity: 1 !important; transform: none !important; }
      </style>
    </noscript>

    
  </head>
<script is:inline>
  const initFade = () => {
    const els = document.querySelectorAll(".fadein");
    if (!els.length) return;

    els.forEach((el) => {
      if (el.dataset.fadeInit === "1") return; // prevent double-init
      el.dataset.fadeInit = "1";

      const y = Number(el.dataset.y || 12);
      el.style.setProperty("--fade-y", y + "px");
    });

    const reveal = (el) => {
      const delay = Number(el.dataset.delay || 0);
      const run = () => requestAnimationFrame(() => el.classList.add("is-in"));
      delay > 0 ? setTimeout(run, delay) : setTimeout(run, 30);
    };

    if (!("IntersectionObserver" in window)) {
      els.forEach(reveal);
      return;
    }

    const io = new IntersectionObserver((entries) => {
      for (const e of entries) {
        if (!e.isIntersecting) continue;
        reveal(e.target);
        if (e.target.dataset.once === "1") io.unobserve(e.target);
      }
    }, { threshold: 0.12 });

    els.forEach((el) => io.observe(el));
  };

  // First load
  document.addEventListener("DOMContentLoaded", initFade);
  // Astro client-side navigations / view transitions
  document.addEventListener("astro:page-load", initFade);
</script>
  <body>
    <header class="nav">
  <div class="nav-inner">
    <div class="logo-sidebar">
      <img src="/images/logo.png" alt="JT Logo" class="logo" />

      <div class="sidebar" aria-label="Site navigation">
        <a href="/">Home</a>
        <a href="/music">Music</a>
        <a href="/lessons">Lessons</a>
        <a href="/me">Me</a>
      </div>
    </div>
  </div>
</header>

   <main>
  <slot />
</main>

    <footer class="wrap muted" style="padding-top:0; padding-bottom:28px;">
      <small>© {new Date().getFullYear()} JT</small>
    </footer>
  </body>
</html>
