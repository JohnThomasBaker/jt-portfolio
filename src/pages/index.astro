---
import BaseLayout from "../layouts/BaseLayout.astro";
import FadeIn from "../components/FadeIn.astro";

const youtubeChannelId = "UCmXK2sDFnmXQu1MqqG7zrGA";
const uploadsPlaylistId = `UU${youtubeChannelId.slice(2)}`;
const youtubeChannelUrl = "https://www.youtube.com/@JohnThomasBaker";
const instagramProfileUrl = "https://www.instagram.com/johnthomasbaker/";
const tiktokProfileUrl = "https://www.tiktok.com/@jtmusicks";
---

<BaseLayout title="JT | Home" description="JT portfolio" mainClass="page-home">
  <!-- HERO (full width) -->
  <FadeIn blur={60} y={0} duration={1200} bg="#C0C2D1">
    <section class="hero">
      <div class="hero-content">
        <div class="hero-title-row">
          <h1 style="color: #B8860B !important;">Welcome to JT's music</h1>
          <h1 class="hero-subtitle">Where JT puts his music</h1>
        </div>
      </div>
      <div class="hero-lately-wrap" aria-label="iPhone video placeholder">
        <aside class="hero-lately-box">
          <button class="hero-lately-trigger" type="button" aria-label="Show latest iPhone video">
            <img src="/images/logo.png" alt="JT logo" />
          </button>
          <div class="hero-lately-video-panel">
            <video controls playsinline preload="metadata">
              <source src="/videos/lately-demo.mp4" type="video/mp4" />
              Your browser does not support the video tag.
            </video>
          </div>
        </aside>
        <p class="hero-lately-caption">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vivamus interdum magna non
          lorem fermentum, sed faucibus ipsum facilisis.
        </p>
      </div>
    </section>
  </FadeIn>
  <!-- ABOUT -->
  <FadeIn>
    <section class="wrap about-wrap">
      <div class="card about">
        <div class="avatar-stack">
          <img class="avatar avatar-main" src="/images/avatar.jpg" alt="JT portrait" />
          <img class="avatar avatar-alt" src="/images/Avatar2.jpg" alt="" />
        </div>
        <div>
          <h2 class="section-title st-red">About JT</h2>
          <p class="muted about-role">
            Composer, percussionist, snare drummer
          </p>
          <p style="margin-bottom: 0;">
            How's it going. I'm JT. I'm a percussionist turned composer currently working in Toledo Ohio. I primarily write percussion and chamber works, often towing the line between the classical/marching percussion worlds and the world of contemporary experimental music. This practice is shared by a lifelong passion for rudimental snare drumming and the marching arts, of which I've spent time as a performer, writer and teacher. 

Here you can access my work, buy music, and get in contact with me. Thanks for coming
          </p>
        </div>
      </div>
    </section>
  </FadeIn>

  <!-- FEATURED -->
  <FadeIn delay={120}>
    <section class="wrap featured-wrap">
      <div class="card media-stack">
        <div class="media-stack-head">
          <h2 class="section-title st-navy">Check This Stuff Out</h2>
          <a class="media-all-link" href="/music">
            <span>View all Media</span>
            <span class="media-all-arrow" aria-hidden="true">→</span>
          </a>
        </div>

        <div class="media-pyramid media-stack-rotator" data-social-stack>
          <button
            class="media-rotate media-rotate-prev"
            type="button"
            aria-label="Show previous social link"
            data-social-prev
          >
            &#8249;
          </button>
          <button
            class="media-rotate media-rotate-next"
            type="button"
            aria-label="Show next social link"
            data-social-next
          >
            &#8250;
          </button>

          <article class="media-scroll media-scroll-youtube is-front" data-social-card>
            <h3 class="media-title-youtube">YouTube</h3>
            <div class="video">
              <iframe
                id="jt-featured-gallery"
                data-channel-playlist
                src={`https://www.youtube.com/embed/videoseries?list=${uploadsPlaylistId}&autoplay=1&mute=1&rel=0&modestbranding=1&enablejsapi=1`}
                title="Featured video gallery"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
            <a href={youtubeChannelUrl} target="_blank" rel="noopener noreferrer">@JohnThomasBaker</a>
          </article>

          <article class="media-scroll media-scroll-social media-scroll-instagram is-back-right" data-social-card>
            <h3 class="media-title-instagram">Instagram</h3>
            <iframe
              src="https://www.instagram.com/johnthomasbaker/embed"
              title="Instagram profile preview"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
            <a href={instagramProfileUrl} target="_blank" rel="noopener noreferrer">@johnthomasbaker</a>
          </article>

          <article class="media-scroll media-scroll-social media-scroll-tiktok is-back-left" data-social-card>
            <h3 class="media-title-tiktok">TikTok</h3>
            <iframe
              src="https://www.tiktok.com/@jtmusicks"
              title="TikTok profile preview"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
            <a href={tiktokProfileUrl} target="_blank" rel="noopener noreferrer">@jtmusicks</a>
          </article>
        </div>
      </div>
    </section>
  </FadeIn>

  <!-- MUSIC GRID -->
  <FadeIn delay={240} y={18}>
    <section class="wrap">
      <h2 class="section-title st-red" style="margin-bottom: 0.75rem;">Featured Works</h2>

      <div class="music-grid">
        <a class="card card-link" href="/music">
          <div class="thumb"></div>
          <div class="card-body">
            <h3 class="card-title">Piece Title 1</h3>
            <p class="muted">for ensemble · 2025</p>
          </div>
        </a>

        <a class="card card-link" href="/music">
          <div class="thumb"></div>
          <div class="card-body">
            <h3 class="card-title">Piece Title 2</h3>
            <p class="muted">solo · 2024</p>
          </div>
        </a>

        <a class="card card-link" href="/music">
          <div class="thumb"></div>
          <div class="card-body">
            <h3 class="card-title">Piece Title 3</h3>
            <p class="muted">chamber · 2023</p>
          </div>
        </a>

        <a class="card card-link" href="/music">
          <div class="thumb"></div>
          <div class="card-body">
            <h3 class="card-title">Piece Title 4</h3>
            <p class="muted">percussion · 2022</p>
          </div>
        </a>
      </div>
    </section>
  </FadeIn>

  <!-- NEWS -->
  <FadeIn delay={360} y={18}>
    <section class="wrap">
      <h2 class="section-title" style="margin-bottom: 0.75rem;">JT News</h2>

      <div class="news">
        <a class="card card-link news-item" href="#">
          <div class="news-thumb"></div>
          <div>
            <h3 class="card-title">Update title goes here</h3>
            <p class="muted" style="margin: 0.25rem 0 0;">
              A short teaser sentence. Click to read more.
            </p>
          </div>
        </a>

        <a class="card card-link news-item" href="#">
          <div class="news-thumb"></div>
          <div>
            <h3 class="card-title">Another update</h3>
            <p class="muted" style="margin: 0.25rem 0 0;">
              Another teaser sentence. Click to read more.
            </p>
          </div>
        </a>
      </div>
    </section>
  </FadeIn>
</BaseLayout>

<script is:inline>
  const loadYouTubeIframeApi = () =>
    new Promise((resolve) => {
      if (window.YT?.Player) {
        resolve(window.YT);
        return;
      }

      if (!window.__jtYouTubeApiPromise) {
        window.__jtYouTubeApiPromise = new Promise((ready) => {
          const existing = document.querySelector('script[src="https://www.youtube.com/iframe_api"]');
          if (!existing) {
            const script = document.createElement("script");
            script.src = "https://www.youtube.com/iframe_api";
            document.head.appendChild(script);
          }

          const previous = window.onYouTubeIframeAPIReady;
          window.onYouTubeIframeAPIReady = () => {
            previous?.();
            ready(window.YT);
          };
        });
      }

      window.__jtYouTubeApiPromise.then(resolve);
    });

  const initFeaturedVideoGallery = () => {
    const frame = document.querySelector("[data-channel-playlist]");
    if (!frame) return;

    window.__jtVideoGalleryCleanup?.();
    const pendingTimeouts = [];
    let timer = null;
    let player = null;

    const queue = (fn, ms) => {
      const id = window.setTimeout(fn, ms);
      pendingTimeouts.push(id);
    };

    const seekHalfway = () => {
      if (!player?.getDuration) return;
      const duration = player.getDuration();
      if (!duration || !Number.isFinite(duration)) return;
      player.seekTo(duration * 0.5, true);
    };

    loadYouTubeIframeApi().then((YT) => {
      if (!frame.id) frame.id = "jt-featured-gallery";

      player = new YT.Player(frame.id, {
        events: {
          onReady: () => {
            player.playVideo();
            queue(seekHalfway, 1000);

            timer = window.setInterval(() => {
              player.nextVideo();
              queue(seekHalfway, 1200);
            }, 15000);
          },
        },
      });
    });

    window.__jtVideoGalleryCleanup = () => {
      pendingTimeouts.forEach((id) => window.clearTimeout(id));
      if (timer) window.clearInterval(timer);
      if (player?.destroy) player.destroy();
    };
  };

  initFeaturedVideoGallery();
  document.addEventListener("DOMContentLoaded", initFeaturedVideoGallery);
  document.addEventListener("astro:page-load", initFeaturedVideoGallery);

  const initSocialStackCycle = () => {
    const stack = document.querySelector("[data-social-stack]");
    if (!stack) return;

    const cards = Array.from(stack.querySelectorAll("[data-social-card]"));
    if (cards.length !== 3) return;
    const prevButton = stack.querySelector("[data-social-prev]");
    const nextButton = stack.querySelector("[data-social-next]");

    window.__jtSocialStackCleanup?.();

    let frontIndex = 0;
    let interval = null;

    const updatePositions = () => {
      cards.forEach((card, index) => {
        const offset = (index - frontIndex + cards.length) % cards.length;
        card.classList.remove("is-front", "is-back-left", "is-back-right");
        if (offset === 0) card.classList.add("is-front");
        if (offset === 1) card.classList.add("is-back-right");
        if (offset === 2) card.classList.add("is-back-left");
      });
    };

    const restartInterval = () => {
      if (interval) window.clearInterval(interval);
      interval = window.setInterval(() => {
        frontIndex = (frontIndex + 1) % cards.length;
        updatePositions();
      }, 10000);
    };

    const goNext = () => {
      frontIndex = (frontIndex + 1) % cards.length;
      updatePositions();
      restartInterval();
    };

    const goPrev = () => {
      frontIndex = (frontIndex - 1 + cards.length) % cards.length;
      updatePositions();
      restartInterval();
    };

    prevButton?.addEventListener("click", goPrev);
    nextButton?.addEventListener("click", goNext);
    updatePositions();
    restartInterval();

    window.__jtSocialStackCleanup = () => {
      if (interval) window.clearInterval(interval);
      prevButton?.removeEventListener("click", goPrev);
      nextButton?.removeEventListener("click", goNext);
    };
  };

  initSocialStackCycle();
  document.addEventListener("DOMContentLoaded", initSocialStackCycle);
  document.addEventListener("astro:page-load", initSocialStackCycle);
</script>

<style>
  .about-wrap {
    padding-bottom: 10px;
  }

  .hero {
    overflow: visible;
  }

  .hero-lately-wrap {
    position: absolute;
    right: -12rem;
    top: calc(100% + 28px);
    bottom: auto;
    transform: none;
    transform-origin: right top;
    z-index: 3;
    width: min(360px, 38vw);
  }

  .hero-lately-box {
    position: relative;
    width: fit-content;
    overflow: visible;
  }

  .hero-lately-trigger {
    width: 90px;
    height: 90px;
    border: none;
    background: transparent;
    cursor: pointer;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: opacity 180ms ease;
  }

  .hero-lately-trigger::before {
    content: "";
    position: absolute;
    inset: -18px -28px;
  }

  .hero-lately-trigger img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .hero-lately-video-panel {
    position: absolute;
    right: 0;
    top: 0;
    width: min(150px, 18vw);
    aspect-ratio: 9 / 16;
    background: linear-gradient(160deg, #222735 0%, #141925 100%);
    border: 1px solid rgba(33, 38, 52, 0.45);
    box-shadow: 0 14px 28px rgba(20, 23, 33, 0.32);
    opacity: 0;
    transform: translateY(10px) scale(0.97);
    transform-origin: right bottom;
    pointer-events: none;
    transition: opacity 220ms ease, transform 220ms ease;
  }

  .hero-lately-video-panel video {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    background: #0f1117;
  }

  .hero-lately-wrap:hover .hero-lately-video-panel,
  .hero-lately-wrap:focus-within .hero-lately-video-panel {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .hero-lately-wrap:hover .hero-lately-trigger,
  .hero-lately-wrap:focus-within .hero-lately-trigger {
    opacity: 0;
  }

  .hero-lately-caption {
    margin: 0.48rem 0 0;
    font-family: "Times New Roman", Times, serif;
    font-size: 0.94rem;
    line-height: 1.25;
    color: #323c4f !important;
    opacity: 0;
    transform: translateY(6px);
    pointer-events: none;
    transition: opacity 220ms ease, transform 220ms ease;
  }

  .hero-lately-wrap:hover .hero-lately-caption,
  .hero-lately-wrap:focus-within .hero-lately-caption {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .featured-wrap {
    padding-top: 10px;
  }

  .media-stack {
    padding-top: 1.1rem;
  }

  .about-role {
    margin: -0.22rem 0 0.3rem !important;
    font-size: clamp(1.56rem, 1.98vw, 2.04rem) !important;
    line-height: 0.98 !important;
    font-family: "JTDisplay", system-ui, sans-serif;
  }

  .about .section-title.st-red {
    margin-bottom: 0 !important;
  }

  .media-stack-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.2rem;
    width: 100%;
  }

  .media-stack-head h2 {
    margin: 0;
  }

  .media-all-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    justify-self: end;
    margin-right: 14px;
    color: var(--tone-slate) !important;
    text-decoration: none;
    font-family: "Times New Roman", Times, serif;
    font-size: 1.05rem;
    white-space: nowrap;
  }

  .media-all-link:hover {
    color: var(--tone-slate) !important;
    text-decoration: underline;
  }

  .media-all-arrow {
    width: 1.45rem;
    height: 1.45rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid currentColor;
    line-height: 1;
    color: var(--tone-slate) !important;
  }

  .media-pyramid {
    position: relative;
    min-height: 600px;
    width: min(100%, 620px);
    margin: 0.5rem auto 0;
  }

  .media-rotate {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 2.1rem;
    height: 2.1rem;
    border: 1px solid rgba(75, 91, 118, 0.45);
    background: var(--nav-reveal-bg);
    color: var(--tone-slate);
    font-family: "JTDisplay", system-ui, sans-serif;
    font-size: 1.5rem;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    z-index: 4;
    cursor: pointer;
  }

  .media-rotate:hover {
    background: rgba(154, 165, 192, 0.88);
  }

  .media-rotate-prev {
    left: -4.4rem;
  }

  .media-rotate-next {
    right: -4.4rem;
  }

  .media-scroll {
    position: absolute;
    inset: 0;
    border: none;
    background: var(--nav-reveal-bg);
    backdrop-filter: blur(4px);
    padding: 0.75rem;
    transition: transform 560ms ease, opacity 560ms ease, filter 560ms ease;
  }

  .media-scroll h3 {
    margin: 0 0 0.45rem;
    font-family: "Jacquard24", serif;
    font-size: 5.7rem;
    color: var(--tone-heading);
    text-align: center;
  }

  .media-scroll h3.media-title-youtube {
    color: var(--tone-slate) !important;
  }

  .media-scroll h3.media-title-instagram {
    color: var(--tone-plum) !important;
  }

  .media-scroll h3.media-title-tiktok {
    color: var(--tone-teal) !important;
  }

  .media-scroll-youtube {
    width: 100%;
  }

  .media-scroll-youtube .video {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: rgba(75, 91, 118, 0.12);
  }

  .media-scroll-youtube .video iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .media-scroll-social iframe {
    width: 100%;
    height: 300px;
    border: none;
    background: transparent;
  }

  .media-scroll a {
    margin-top: 0.45rem;
    display: block;
    text-align: center;
    font-family: "JTDisplay", system-ui, sans-serif;
    font-size: 1.05rem;
    color: var(--tone-plum);
    text-decoration: none;
  }

  .media-scroll a:hover {
    text-decoration: underline;
  }

  .media-scroll.is-front {
    z-index: 3;
    transform: translate3d(0, 0, 0) scale(1);
    opacity: 1;
    filter: none;
    pointer-events: auto;
  }

  .media-scroll.is-back-left {
    z-index: 1;
    transform: translate3d(-16%, 8%, 0) scale(0.82);
    opacity: 0.82;
    filter: saturate(0.88);
    pointer-events: none;
  }

  .media-scroll.is-back-right {
    z-index: 2;
    transform: translate3d(16%, 8%, 0) scale(0.82);
    opacity: 0.82;
    filter: saturate(0.88);
    pointer-events: none;
  }

  @media (max-width: 840px) {
    .hero-lately-wrap {
      width: min(260px, 48vw);
      right: -8rem;
      top: calc(100% + 20px);
      bottom: auto;
    }

    .media-pyramid {
      min-height: 480px;
      width: 100%;
    }

    .media-scroll-youtube {
      width: 100%;
    }

    .media-scroll h3 {
      font-size: 4.1rem;
    }

    .media-scroll-social iframe {
      height: 250px;
    }

    .media-rotate-prev {
      left: -2.6rem;
    }

    .media-rotate-next {
      right: -2.6rem;
    }

    .media-scroll.is-back-left {
      transform: translate3d(-8%, 7%, 0) scale(0.85);
    }

    .media-scroll.is-back-right {
      transform: translate3d(8%, 7%, 0) scale(0.85);
    }
  }

  @media (max-width: 640px) {
    .hero-lately-wrap {
      width: min(220px, 52vw);
      right: -5rem;
      top: calc(100% + 16px);
      bottom: auto;
    }

  }
</style>
