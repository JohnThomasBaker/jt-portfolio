---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="JT | Lessons" description="Lesson info">
  <section class="lessons-page">
    <header class="lessons-header">
      <div class="lessons-header-copy">
        <h1>Lessons</h1>
        <p>
          Alongside my compositional practice I continue to stay involved in the marching arts, mainly through teaching at the Santa Clara Vanguard and through maintaining a modest private lesson studio. Anyone that knows me knows that there's not much I love more than drumming/talking about drumming with people, and my door is always open to anyone interested in advancing their skill and understanding of snare drum.
          Fill out the form below and I'll reach out to you with more information.
        </p>
      </div>
      <figure class="lessons-photo-box" aria-label="Lesson photo area">
        <img src="/Teaching.jpeg" alt="JT teaching" loading="lazy" />
      </figure>
    </header>

    <div class="lessons-form-wrap card">
      <h2 class="section-title st-teal">Private Lesson Request Form</h2>

      <form
        class="lesson-form"
        name="lesson-inquiry"
        method="POST"
        data-netlify="true"
        netlify-honeypot="company"
        data-lesson-form
      >
        <input type="hidden" name="form-name" value="lesson-inquiry" />

        <p class="sr-only">
          <label>
            Company
            <input name="company" />
          </label>
        </p>

        <div class="lesson-grid">
          <label>
            Full Name
            <input type="text" name="name" autocomplete="name" required />
          </label>

          <label>
            Email
            <input type="email" name="email" autocomplete="email" />
          </label>

          <label>
            Phone Number
            <input type="tel" name="phone" autocomplete="tel" />
          </label>

          <label>
            Location
            <input type="text" name="location" autocomplete="address-level2" required />
          </label>
        </div>

        <fieldset class="contact-choice">
          <legend>Preferred Contact Method</legend>
          <label class="choice-item">
            <input type="radio" name="preferred_contact" value="email" required />
            <span>Email</span>
          </label>
          <label class="choice-item">
            <input type="radio" name="preferred_contact" value="phone" required />
            <span>Phone</span>
          </label>
        </fieldset>

        <label>
          Message (optional)
          <textarea
            name="message"
            rows="5"
            placeholder="Anything you'd like me to know before I reach out."
          ></textarea>
        </label>

        <button type="submit">Submit Request</button>
        <p class="form-status muted" data-form-status aria-live="polite"></p>
      </form>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const initLessonForm = () => {
    const form = document.querySelector("[data-lesson-form]");
    if (!form) return;

    const status = form.querySelector("[data-form-status]");
    const button = form.querySelector('button[type="submit"]');
    const emailInput = form.querySelector('input[name="email"]');
    const phoneInput = form.querySelector('input[name="phone"]');

    const validatePreferredContact = () => {
      const selected = form.querySelector('input[name="preferred_contact"]:checked');
      if (!selected) return true;

      if (selected.value === "email" && emailInput && !String(emailInput.value).trim()) {
        emailInput.setCustomValidity("Enter an email address or choose Phone.");
        emailInput.reportValidity();
        return false;
      }

      if (selected.value === "phone" && phoneInput && !String(phoneInput.value).trim()) {
        phoneInput.setCustomValidity("Enter a phone number or choose Email.");
        phoneInput.reportValidity();
        return false;
      }

      if (emailInput) emailInput.setCustomValidity("");
      if (phoneInput) phoneInput.setCustomValidity("");
      return true;
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!form.reportValidity()) return;
      if (!validatePreferredContact()) return;

      const formData = new FormData(form);
      const body = new URLSearchParams(formData).toString();

      if (status) status.textContent = "Sending...";
      if (button) button.disabled = true;

      try {
        const res = await fetch("/", {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body,
        });

        if (!res.ok) throw new Error("submit-failed");
        form.reset();
        if (status) status.textContent = "Request sent. I will be in touch soon.";
      } catch (err) {
        console.error(err);
        if (status) status.textContent = "Could not submit right now. Please try again.";
      } finally {
        if (button) button.disabled = false;
      }
    });

    if (emailInput) emailInput.addEventListener("input", () => emailInput.setCustomValidity(""));
    if (phoneInput) phoneInput.addEventListener("input", () => phoneInput.setCustomValidity(""));
  };

  document.addEventListener("DOMContentLoaded", initLessonForm);
  document.addEventListener("astro:page-load", initLessonForm);
</script>

<style>
  .lessons-page {
    display: grid;
    gap: 1.25rem;
    margin-top: 0.25rem;
  }

  .lessons-header {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(220px, 0.75fr);
    gap: 1rem;
    align-items: stretch;
    padding: 1.15rem 1.35rem;
    background: rgba(255, 255, 255, 0.28);
    border: none;
  }

  .lessons-header-copy h1 {
    margin-bottom: 0.3rem;
  }

  .lessons-header-copy p {
    margin: 0;
    text-align: justify;
  }

  .lessons-photo-box {
    margin: 0;
    width: 80%;
    justify-self: end;
    min-height: 190px;
    border: 1px solid rgba(72, 85, 110, 0.18);
    background: rgba(255, 255, 255, 0.38);
    overflow: hidden;
  }

  .lessons-photo-box img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .lessons-form-wrap {
    padding: 1.15rem;
    background: rgba(255, 255, 255, 0.32);
    border: 1px solid rgba(72, 85, 110, 0.16);
  }

  .lessons-form-wrap h2 {
    margin-bottom: 0.45rem;
    text-align: center !important;
  }

  .lessons-note {
    margin: 0 0 0.8rem;
    font-size: 0.96rem;
  }

  .lesson-form {
    display: grid;
    gap: 0.8rem;
  }

  .lesson-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
  }

  .lesson-form label {
    display: grid;
    gap: 0.28rem;
    font-family: "JTDisplay", system-ui, sans-serif;
    font-weight: 700;
    color: var(--tone-slate);
    letter-spacing: 0.02em;
  }

  .contact-choice {
    border: 1px solid rgba(72, 85, 110, 0.2);
    padding: 0.6rem 0.7rem;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    align-items: center;
  }

  .contact-choice legend {
    font-family: "JTDisplay", system-ui, sans-serif;
    font-weight: 700;
    color: var(--tone-slate);
    padding: 0 0.25rem;
  }

  .choice-item {
    display: inline-flex !important;
    align-items: center;
    gap: 0.35rem;
    color: var(--text) !important;
  }

  .lesson-form input,
  .lesson-form select,
  .lesson-form textarea {
    width: 100%;
    font: inherit;
    color: var(--text);
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(72, 85, 110, 0.2);
    padding: 0.65rem 0.7rem;
    border-radius: 0;
  }

  .lesson-form textarea {
    resize: vertical;
    min-height: 8rem;
  }

  .lesson-form input:focus,
  .lesson-form select:focus,
  .lesson-form textarea:focus {
    outline: none;
    border-color: rgba(74, 93, 131, 0.7);
    background: rgba(255, 255, 255, 0.9);
  }

  .lesson-form button {
    justify-self: center;
    padding: 0.55rem 0.95rem;
    border: none;
    background: transparent;
    color: var(--tone-teal);
    font-family: "Jacquard24", serif;
    font-size: 4.48rem;
    line-height: 1;
    cursor: pointer;
  }

  .lesson-form button:hover {
    background: transparent;
    text-decoration: none;
    transform: scale(1.2);
  }

  .lesson-form button:disabled {
    opacity: 0.7;
    cursor: wait;
  }

  .form-status {
    margin: 0.1rem 0 0;
    min-height: 1.2em;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 720px) {
    .lessons-header {
      grid-template-columns: 1fr;
    }

    .lessons-header,
    .lessons-form-wrap {
      padding: 0.95rem;
    }

    .lessons-photo-box {
      min-height: 150px;
    }

    .lesson-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
